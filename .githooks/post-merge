#!/bin/bash
# Auto-remove AI config files from index on main branch after merge
# These files are tracked on dev but should not appear on main

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ]; then
  exit 0
fi

# Remove AI config files from index (keep on disk)
git rm --cached -r .claude/ .codex/ .agents/ openspec/ 2>/dev/null
git rm --cached skills-lock.json CLAUDE.md 2>/dev/null

# Only commit if there are staged changes
if ! git diff --cached --quiet 2>/dev/null; then
  git commit -m "chore(auto): re-exclude AI config files from main"
  echo "[post-merge hook] AI config files removed from main index."
fi
