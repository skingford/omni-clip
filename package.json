{
  "name": "omni-clip-monorepo",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "bun run --filter @omni-clip/web dev",
    "dev:core": "bun run --filter @omni-clip/core dev",
    "build": "bun run --filter '*' build",
    "start": "bun run packages/core/src/cli.ts"
  }
}
